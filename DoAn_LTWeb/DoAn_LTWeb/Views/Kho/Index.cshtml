
@{
    ViewBag.Title = "QUẢN LÝ KHO";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@model List<DoAn_LTWeb.Models.KhoSanPhamVM>


<h3 class="fw-bold mb-3">QUẢN LÝ KHO HÀNG</h3>

<form class="row mb-3">
    <div class="col-md-4">
        <input type="text" name="keyword" class="form-control"
               placeholder="Tìm theo tên sản phẩm" />
    </div>
    <div class="col-md-3">
        <select class="form-select" name="maDanhMuc">
            <option value="">-- Danh mục --</option>
            @foreach (var dm in ViewBag.DanhMuc)
            {
                <option value="@dm.MaDanhMuc">@dm.TenDanhMuc</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <button class="btn btn-primary">Lọc</button>
    </div>
</form>

<table class="table table-bordered table-hover text-center">
    <thead class="table-dark">
        <tr>
            <th>STT</th>
            <th>Sản phẩm</th>
            <th>Danh mục</th>
            <th>Giá</th>
            <th>Tồn kho</th>
            <th>Cập nhật</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr class="@(item.SoLuongTon <= 10 ? "table-danger" : "")">
                <td>@item.MaSanPham</td>
                <td>@item.TenSanPham</td>
                <td>@item.TenDanhMuc</td>
                <td>@((item.Gia ?? 0).ToString("N0"))</td>
                <td><strong>@item.SoLuongTon</strong></td>
                <td>
                    <form action="/Kho/CapNhatSoLuong" method="post" class="d-flex">
                        <input type="hidden" name="maSanPham" value="@item.MaSanPham" />
                        <input type="number" name="soLuongMoi"
                               class="form-control form-control-sm me-2"
                               min="0" value="@item.SoLuongTon" />
                        <button class="btn btn-success btn-sm">Lưu</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

<p class="text-danger">
    Các sản phẩm nền đỏ là hàng sắp hết (≤ 10)
</p>
