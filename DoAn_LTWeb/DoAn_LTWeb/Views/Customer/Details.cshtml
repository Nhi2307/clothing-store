@model DoAn_LTWeb.Models.NguoiDung

@{
    ViewBag.Title = "Thông tin khách hàng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2>Thông tin khách hàng</h2>

<table class="table table-bordered">
    <tr><th>Mã khách hàng:</th><td>@Model.MaNguoiDung</td></tr>
    <tr><th>Họ tên:</th><td>@Model.HoTen</td></tr>
    <tr><th>Email:</th><td>@Model.Email</td></tr>
    <tr><th>Tài khoản:</th><td>@Model.TaiKhoan</td></tr>
    <tr><th>Số điện thoại:</th><td>@Model.SoDienThoai</td></tr>
    <tr><th>Địa chỉ:</th><td>@Model.DiaChi</td></tr>
    <tr>
        <th>Ngày tạo:</th>
        <td>@(Model.NgayTao.HasValue ? Model.NgayTao.Value.ToString("dd/MM/yyyy") : "")</td>
    </tr>
    <tr><th>Vai trò:</th><td>@Model.VaiTro</td></tr>
    <tr>
        <th>Trạng thái</th>
        <td>
            @if (Model.TrangThai == true)
            {
                <span class="badge bg-success">Hoạt động</span>
            }
            else
            {
                <span class="badge bg-danger">Đã khóa</span>
            }
        </td>
    </tr>
</table>

<div class="mt-3">

    @if (Session["VaiTro"] != null && Session["VaiTro"].ToString() == "Admin")
    {
        if (Model.TrangThai == true)
        {
            <a href="@Url.Action("Khoa", "Customer", new { id = Model.MaNguoiDung })"
               class="btn btn-danger"
               onclick="return confirm('Bạn có chắc muốn khóa tài khoản này?')">
                🔒 Khóa tài khoản
            </a>
        }
        else
        {
            <a href="@Url.Action("MoKhoa", "Customer", new { id = Model.MaNguoiDung })"
               class="btn btn-success"
               onclick="return confirm('Bạn có chắc muốn mở khóa tài khoản này?')">
                🔓 Mở khóa tài khoản
            </a>
        }
    }

</div>


<a href="@Url.Action("Index")" class="btn btn-secondary">Quay lại</a>
