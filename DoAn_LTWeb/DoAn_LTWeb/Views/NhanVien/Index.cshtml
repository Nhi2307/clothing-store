@{
    ViewBag.Title = "Dashboard Nhân viên";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row">


    <div class="col-md-4">
        <a href="@Url.Action("Index", "Product")" class="text-decoration-none text-dark">
            <div class="stats-card">
                <i class="fas fa-box fa-2x"></i>
                <h3>@(ViewBag.TotalProducts ?? 0)</h3>
                <p class="mb-0">Sản phẩm</p>
            </div>
        </a>
    </div>


    <div class="col-md-4">
        <a href="@Url.Action("Index", "Order")" class="text-decoration-none text-dark">
            <div class="stats-card" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
                <i class="fas fa-shopping-cart fa-2x"></i>
                <h3>@(ViewBag.TotalOrders ?? 0)</h3>
                <p class="mb-0">Đơn hàng</p>
            </div>
        </a>
    </div>


    <div class="col-md-4">
        <a href="@Url.Action("Index", "Order", new { status = "Chờ xác nhận" })"
           class="text-decoration-none text-dark">
            <div class="stats-card"
                 style="background: linear-gradient(135deg, #ffb347 0%, #ffcc33 100%);">
                <i class="fas fa-clock fa-2x"></i>
                <h3>@(ViewBag.PendingOrders ?? 0)</h3>
                <p class="mb-0">Chờ xử lý</p>
            </div>
        </a>
    </div>


</div>


<div class="row mt-4">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="fas fa-bolt"></i>
                    Công việc nhanh
                </h5>
            </div>

            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <a href="@Url.Action("Index", "Order")"
                           class="btn btn-primary w-100">
                            <i class="fas fa-list"></i> Xử lý đơn hàng
                        </a>
                    </div>

                    <div class="col-md-4 mb-3">
                        <a href="@Url.Action("Index", "Product")"
                           class="btn btn-info w-100 text-white">
                            <i class="fas fa-box"></i> Xem sản phẩm
                        </a>
                    </div>

                    <div class="col-md-4 mb-3">
                        <a href="@Url.Action("DSLienHe", "LienHe")"
                           class="btn btn-warning w-100 text-white">
                            <i class="fas fa-envelope"></i> Liên hệ KH
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            <i class="fas fa-history"></i>
            Đơn hàng gần đây
        </h5>
        <a href="@Url.Action("Index", "Order")" class="btn btn-sm btn-primary">
            Xem tất cả
        </a>
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Mã đơn</th>
                        <th>Khách hàng</th>
                        <th>Ngày đặt</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>

                <tbody>
                    @if (ViewBag.RecentOrders != null && ViewBag.RecentOrders.Count > 0)
                    {
                        foreach (var order in ViewBag.RecentOrders)
                        {
                            string status = order.TrangThai ?? "";
                            string badgeClass = "bg-secondary";

                            switch (status)
                            {
                                case "Chờ xác nhận":
                                    badgeClass = "bg-warning";
                                    break;

                                case "Đang giao":
                                    badgeClass = "bg-info";
                                    break;

                                case "Hoàn thành":
                                    badgeClass = "bg-success";
                                    break;

                                case "Hủy":
                                    badgeClass = "bg-danger";
                                    break;
                            }

                            <tr>
                                <td><strong>@order.MaDonHang</strong></td>
                                <td>@(order.NguoiDung == null ? "Không rõ" : order.NguoiDung.HoTen)</td>
                                <td>@(order.NgayDat == null ? "" : order.NgayDat.ToString("dd/MM/yyyy HH:mm"))</td>
                                <td><strong>@String.Format("{0:N0}", order.TongTien ?? 0) đ</strong></td>

                                <td>
                                    <span class="badge @badgeClass">@(status == "" ? "Không rõ" : status)</span>
                                </td>

                                <td>
                                    <a href="@Url.Action("Index", "Order", new { id = order.MaDonHang })"
                                       class="btn btn-sm btn-primary">
                                        <i class="fas fa-eye"></i> Chi tiết
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center">
                                <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                                <p class="text-muted">Chưa có đơn hàng nào</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
