@model IEnumerable<DoAn_LTWeb.Models.LienHe>

@{
    ViewBag.Title = "Liên hệ khách hàng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h4 class="mb-3">
    <i class="fas fa-envelope"></i> Liên hệ từ khách hàng
</h4>

<table class="table table-hover">
    <thead class="table-light">
        <tr>
            <th>Họ tên</th>
            <th>Email</th>
            <th>Nội dung</th>
            <th>Ngày gửi</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var l in Model)
        {
            <tr>
                <td>@l.Name</td>
                <td>@l.Email</td>
                <td>@l.Message</td>
                <td>@l.CreatedAt.Value.ToString("dd/MM/yyyy HH:mm")</td>
            </tr>
        }
    </tbody>
</table>
