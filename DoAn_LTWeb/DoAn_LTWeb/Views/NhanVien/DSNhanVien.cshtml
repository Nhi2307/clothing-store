@model IEnumerable<DoAn_LTWeb.Models.NguoiDung>

@{
    ViewBag.Title = "Quản lý nhân viên";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    string vaiTro = Session["VaiTro"]?.ToString();
    bool isAdmin = vaiTro == "Admin";
}

<h3 class="mb-3"> Quản lý nhân viên </h3>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mt-2">
        <i class="fas fa-check-circle"></i>
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}


<div class="row align-items-center mb-3">
    <div class="col-md-4">
        @if (isAdmin)
        {
            <a href="@Url.Action("ThemNhanVien")" class="btn btn-primary">
                <i class="fas fa-user-plus"></i> Thêm nhân viên
            </a>
        }
    </div>

    <div class="col-md-8">
        @using (Html.BeginForm("DSNhanVien", "NhanVien", FormMethod.Get))
        {
            <div class="d-flex justify-content-end gap-2">
                <input type="text"
                       name="keyword"
                       value="@ViewBag.Keyword"
                       class="form-control w-50"
                       placeholder="Tìm theo tên nhân viên..." />

                <button type="submit" class="btn btn-secondary">
                    <i class="fas fa-search"></i>
                </button>

                <a href="@Url.Action("DSNhanVien")" class="btn btn-outline-secondary">
                    <i class="fas fa-undo"></i>
                </a>
            </div>
        }
    </div>
</div>



<table class="table table-bordered">
    <thead>
        <tr>
            <th>Mã NV</th>
            <th>Họ tên</th>
            <th>Email</th>
            <th>SĐT</th>
            <th>Địa chỉ</th>
            <th>Thao tác</th>
        </tr>
    </thead>

    <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="6" class="text-center text-muted">
                    Chưa có nhân viên nào
                </td>
            </tr>
        }
        else
        {
            foreach (var nv in Model)
            {
                <tr>
                    <td>@nv.MaNguoiDung</td>
                    <td>@nv.HoTen</td>
                    <td>@nv.Email</td>
                    <td>@nv.SoDienThoai</td>
                    <td>@nv.DiaChi</td>

                    <td>
                        <a href="@Url.Action("SuaNhanVien", new { id = nv.MaNguoiDung })"
                           class="btn btn-warning btn-sm">
                            <i class="fas fa-edit"></i> Sửa
                        </a>

                        @if (isAdmin)
                        {
                            <a href="@Url.Action("XoaNhanVien", new { id = nv.MaNguoiDung })"
                               class="btn btn-danger btn-sm"
                               onclick="return confirm('Bạn có chắc muốn xóa nhân viên này không?');">
                                <i class="fas fa-trash"></i> Xóa
                            </a>
                        }
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
