@model IEnumerable<DoAn_LTWeb.Models.DonHangVM>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mt-2">
        <i class="fas fa-check-circle"></i>
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}


@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<h3 class="mb-4">Lịch sử đơn hàng</h3>

@foreach (var dh in Model)
{
    <div class="card mb-3 p-3">
        <p><strong>Mã đơn:</strong> #@dh.MaDonHang</p>
        <p><strong>Ngày đặt:</strong> @dh.NgayDat.ToString("dd/MM/yyyy")</p>

        <p>
            <strong>Trạng thái:</strong>
            <span class="badge badge-info">@dh.TrangThai</span>
        </p>

        <hr />
        @if (dh.TrangThai == "Chờ xác nhận")
        {
            using (Html.BeginForm("HuyDon", "Order", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@dh.MaDonHang" />
                <button type="submit"
                        class="btn btn-danger btn-sm"
                        onclick="return confirm('Bạn chắc chắn muốn hủy đơn này?');">
                    Hủy đơn
                </button>
            }
        }


        @foreach (var ct in dh.ChiTiet)
        {
            <div class="d-flex align-items-center mb-3">
                <img src="~/Content/HinhAnh/@ct.HinhAnh" width="70" class="mr-3" />

                <div>
                    <p class="mb-1"><strong>@ct.TenSanPham</strong></p>
                    <p class="mb-1">SL: @ct.SoLuong</p>

                    @if (dh.TrangThai == "Hoàn thành")
                    {
                        if (!ct.DaDanhGia)
                        {
                            <a href="@Url.Action("ThemDanhGia", "DanhGia", new { id = ct.MaSanPham })"
                               class="btn btn-sm btn-success">
                                Đánh giá sản phẩm
                            </a>
                        }
                        else
                        {
                            <span class="text-success">Đã đánh giá</span>
                        }
                    }
                </div>
            </div>
        }
    </div>
}

<div class="mt-3">
    <a href="@Url.Action("Profile", "NguoiDung")" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> Quay lại hồ sơ
    </a>
</div>
