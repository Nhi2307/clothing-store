@using DoAn_LTWeb.Models;
@model List<SanPhamDMViewModel>
@{
    ViewBag.Title = "SanPhamTheoDM";
    Layout = "~/Views/Shared/UserLayout.cshtml";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>List Product</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            text-align: center;
            background-color: #f0f0f0;
        }

        h1 {
            margin-top: 20px;
        }

        .book-list {
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: 30px;
            padding: 20px;
        }

        .book-item {
            background-color: white;
            border: 1px solid #ccc;
            padding: 10px;
            width: 200px;
            text-align: center;
            border-radius: 8px;
            box-shadow: 0 0 5px rgba(0,0,0,0.1);
        }

            .book-item img {
                width: 100%;
                height: auto;
            }

            .book-item p {
                margin: 10px 0;
            }

        .price {
            margin: 8px 0;
        }

        .sale-price {
            color: red;
            font-weight: bold;
            font-size: 16px;
        }

        .original-price {
            color: #999;
            text-decoration: line-through;
            margin-right: 5px;
            font-size: 14px;
        }

        .detail-link {
            display: inline-block;
            margin-top: 10px;
            color: #007bff; 
            font-weight: 500;
            text-decoration: none;
            cursor: pointer;
        }

            .detail-link:hover {
                color: #0056b3;
                text-decoration: underline;
            }

        .sale-badge {
            position: absolute;
            background-color: red;
            color: white;
            padding: 3px 6px;
            font-size: 12px;
            border-radius: 4px;
            top: 5px;
            left: 5px;
        }

        .image-wrapper {
            position: relative;
        }
    </style>

</head>
<body>
    <h1> Sản Phẩm Theo Danh Mục @ViewData["DanhMuc"].ToString().ToUpper()</h1>
    <div class="book-list">

        @foreach (var item in Model)
        {
            <div class="book-item">
                <div class="image-wrapper">
                    <img src="~/Content/HinhAnh/@item.HinhAnhChinh" alt="@item.TenSanPham" />
                    @if (item.MucGiam > 0)
                    {
                        <span class="sale-badge">-@item.MucGiam %</span>
                    }
                </div>

                <p class="product-name">@item.TenSanPham</p>

                @if (item.MucGiam > 0)
                {
                    <p class="price">
                        <span class="original-price">@item.GiaGoc.ToString("N0") VNĐ</span>
                        <span class="sale-price">@item.GiaKM.ToString("N0") VNĐ</span>
                    </p>
                }
                else
                {
                    <p class="price">
                        <span class="sale-price">@item.GiaGoc.ToString("N0") VNĐ</span>
                    </p>
                }

            <p class="detail-link">
                <a onclick="location.href='@Url.Action("XemChiTiet", "Product", new { id = item.MaSanPham })'">
                    Xem chi tiết
                </a>
            </p>
            </div>
        }
        @if (Model.Count == 0)
        {
            <a>Không có sản phẩm theo danh mục này!!</a>
        }

    </div>
</body>
</html>