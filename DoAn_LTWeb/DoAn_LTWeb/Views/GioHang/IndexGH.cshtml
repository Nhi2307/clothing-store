@model List<DoAn_LTWeb.Models.CartItem>
@{
    ViewBag.Title = "IndexGH";
    Layout = "~/Views/Shared/UserLayout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

@using (Html.BeginForm("ThanhToan", "GioHang", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    
    <div class="container mt-4">
    <h2>Giỏ Hàng</h2>

    @if (Model == null || !Model.Any())
    {
        <p>Giỏ hàng trống.</p>
        <a href="@Url.Action("IndexDM", "DanhMuc")" class="btn btn-primary">Tiếp tục mua sắm</a>
    }
    else
    {
        <table class="table table-bordered text-center">
            <thead>
                <tr>
                    <th>
                        <input type="checkbox" id="checkAll" />
                    </th>
                    <th>Ảnh</th>
                    <th>Tên sản phẩm</th>
                    <th>Màu</th>
                    <th>Size</th>
                    <th>Giá</th>
                    <th>Số lượng</th>
                    <th>Thành tiền</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <input type="checkbox"
                                   class="chkItem"
                                   name="selectedItems"
                                   value="@item.MaBienThe" />
                        </td>
                        <td>
                            <img src="@Url.Content(item.HinhAnh ?? "~/Content/HinhAnh/no-image.png")"
                                 style="width:70px; height:70px; object-fit:cover;" />
                        </td>
                        <td>@item.TenSanPham</td>
                        <td>@item.TenMau</td>
                        <td>@item.TenSize</td>
                        <td>@item.DonGia.ToString("N0") VNĐ</td>


                        <td>
                            <input type="number"
                                   class="form-control soLuongGH text-center"
                                   data-id="@item.MaBienThe"
                                   data-old="@item.SoLuong"
                                   value="@item.SoLuong"
                                   min="1" />
                        </td>

                        <td>@item.ThanhTien.ToString("N0") VNĐ</td>

                        <td>
                            <button class="btn btn-sm btn-danger btnXoaGH"
                                    data-id="@item.MaBienThe">
                                Xóa
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="6" class="text-end"><strong>Tổng tiền:</strong></td>
                    <td colspan="2"><strong>@(Model.Sum(i => i.ThanhTien).ToString("N0")) VNĐ</strong></td>
                </tr>
            </tfoot>
        </table>

        <div class="mt-3">
            <a href="@Url.Action("IndexDM","DanhMuc")" class="btn btn-primary">Tiếp tục mua sắm</a>
            <button type="button" id="btnThanhToan" class="btn btn-success">
                Thanh toán
            </button>

        </div>
    }
</div>
}



@section scripts {
    <script>

    //chọn tất cả sản phẩm
            $('#checkAll').on('change', function () {
                $('.chkItem').prop('checked', this.checked);
});

        // Lấy token anti forgery
        function getAntiForgeryToken() {
            return $('input[name="__RequestVerificationToken"]').val();
        }

        // Thêm giỏ hàng bằng Ajax (Dùng cho View Chi tiết/Danh mục)
        $(document).on('submit', 'form', function (e) {
            var form = $(this);
            if (form.attr('action').includes('ThemGioHang')) {
                e.preventDefault();

                $.ajax({
                    url: form.attr('action'),
                    type: 'POST',
                    data: form.serialize(),
                    success: function (res) {
                        if (res.success) {
                            $('#cartCount').text(res.cartCount);
                            alert("Đã thêm sản phẩm vào giỏ hàng!");
                        } else {
                            alert(res.message);
                        }
                    },
                    error: function () {
                        alert("Có lỗi xảy ra. Vui lòng thử lại.");
                    }
                });
            }
        });

        // Xóa giỏ hàng bằng Ajax (Dùng cho View Giỏ hàng)
                $(document).on('click', '.btnXoaGH', function () {
            if (!confirm("Bạn có chắc muốn xóa sản phẩm này?")) return;

            var id = $(this).data('id');

            $.ajax({
                url: '@Url.Action("XoaGioHang", "GioHang")',
                type: 'POST',
                data: {
                    MaBienThe: id,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                },
                success: function (res) {
                    if (res.success) {
                        $("#cartCount").text(res.cartCount);
                        location.reload();
                    } else {
                        alert(res.message);
                    }
                },
                error: function () {
                    alert("Lỗi server!");
                }
            });
        });


        // Cập nhật số lượng bằng Ajax (Dùng cho View Giỏ hàng)
        $(document).on('change', '.soLuongGH', function () {
            var input = $(this);
            var MaBienThe = input.data('id');
            var SoLuong = parseInt(input.val()) || 1;

            $.ajax({
                url: '@Url.Action("CapNhatGioHang", "GioHang")',
                type: 'POST',
                data: {
                    MaBienThe: MaBienThe,
                    SoLuong: SoLuong,
                    __RequestVerificationToken: getAntiForgeryToken()
                },
                success: function (res) {
                    if (res.success) {
                        $('#cartCount').text(res.cartCount);
                        location.reload();
                    } else {
                        alert(res.message || "Cập nhật thất bại.");
                    }
                },
                error: function () {
                    alert("Cập nhật thất bại.");
                }
            });
        });

        $('#btnThanhToan').click(function () {
    var selected = $('.chkItem:checked')
        .map(function () { return this.value; })
        .get();

    if (selected.length === 0) {
        alert("Vui lòng chọn ít nhất một sản phẩm!");
        return;
    }

    var url = '@Url.Action("ThanhToan", "GioHang")'
            + '?selectedItems=' + selected.join(',');

    window.location.href = url;
});

    </script>
}