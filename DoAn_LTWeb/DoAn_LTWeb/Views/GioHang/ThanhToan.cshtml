@model List<DoAn_LTWeb.Models.CartItem>

@{
    ViewBag.Title = "Thanh Toán";
    Layout = "~/Views/Shared/UserLayout.cshtml";
}

<div class="container mt-3">
    <h2 class="mb-3">Thanh Toán</h2>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mt-2">
            <i class="fas fa-check-circle"></i>
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-warning">
            Giỏ hàng trống, không thể thanh toán.
        </div>
        <a href="@Url.Action("IndexDM", "DanhMuc")" class="btn btn-primary">
            Tiếp tục mua sắm
        </a>
    }
    else
    {
        <div class="row">


            <div class="col-md-8">
                <h4>Thông tin sản phẩm</h4>

                <table class="table table-bordered text-center">
                    <thead class="table-light">
                        <tr>
                            <th>Ảnh</th>
                            <th>Tên</th>
                            <th>Màu</th>
                            <th>Size</th>
                            <th>Giá</th>
                            <th>SL</th>
                            <th>Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <img src="@Url.Content(item.HinhAnh ?? "~/Content/HinhAnh/no-image.jpg")"
                                         style="width:70px;height:70px;" />
                                </td>
                                <td>@item.TenSanPham</td>
                                <td>@item.TenMau</td>
                                <td>@item.TenSize</td>
                                <td>@item.Gia.ToString("N0") VNĐ</td>
                                <td>@item.SoLuong</td>
                                <td>@item.ThanhTien.ToString("N0") VNĐ</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="6" class="text-end">
                                <strong>Tổng tiền:</strong>
                            </td>
                            <td>
                                <strong class="text-danger">
                                    @Model.Sum(i => i.ThanhTien).ToString("N0") VNĐ
                                </strong>
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>


            <div class="col-md-4">
                <h4>Thông tin khách hàng</h4>

                @using (Html.BeginForm("ThanhToan", "GioHang", FormMethod.Post))
                {

                    @Html.AntiForgeryToken()

                    foreach (var item in Model)
                    {
                        <input type="hidden" name="selectedItems" value="@item.MaBienThe" />
                    }


                    <div class="mb-3">
                        <label class="form-label">Họ tên</label>
                        <input type="text" name="HoTen" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Địa chỉ</label>
                        <input type="text" name="DiaChi" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Số điện thoại</label>
                        <input type="tel" name="SDT" class="form-control"
                               pattern="[0-9]{9,11}" required />
                    </div>


                    <div class="mb-3">
                        <label class="form-label">Phương thức thanh toán</label>

                        <div class="form-check">
                            <input class="form-check-input" type="radio"
                                   name="MaPTTT" value="1" checked />
                            <label class="form-check-label">
                                Thanh toán khi nhận hàng (COD)
                            </label>
                        </div>

                        <div class="form-check">
                            <input class="form-check-input" type="radio"
                                   name="MaPTTT" value="2" />
                            <label class="form-check-label">
                                Chuyển khoản ngân hàng
                            </label>
                        </div>
                    </div>

                    <div class="card p-3 mt-3">
                        <h5 class="text-center">Tổng thanh toán</h5>
                        <h3 class="text-center text-danger">
                            @Model.Sum(i => i.ThanhTien).ToString("N0") VNĐ
                        </h3>

                        <button type="submit" class="btn btn-success w-100 mt-2">
                            Xác nhận thanh toán
                        </button>
                    </div>
                }
            </div>
        </div>
    }
</div>
