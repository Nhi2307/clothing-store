@model IEnumerable<DoAn_LTWeb.Models.DanhGiaVM>

@{
    ViewBag.Title = "Đánh giá của tôi";
}

<h3 class="mb-4">Đánh giá của tôi</h3>

@if (!Model.Any())
{
    <div class="alert alert-info">
        Bạn chưa gửi đánh giá nào.
    </div>
}
else
{
    foreach (var dg in Model)
    {
        <div class="card mb-4 shadow-sm">
            <div class="card-body">


                <div class="d-flex align-items-center mb-3">
                    <img src="~/Content/HinhAnh/@dg.HinhAnh"
                         width="80"
                         class="mr-3 rounded border" />

                    <div>
                        <h5 class="mb-1">@dg.TenSanPham</h5>
                        <small class="text-muted">
                            Ngày đánh giá: @dg.NgayDG.ToString("dd/MM/yyyy")
                        </small>
                    </div>
                </div>


                <p class="mb-1">
                    <strong>Số sao:</strong>
                    @for (int i = 1; i <= 5; i++)
                    {
                        if (i <= dg.Sao)
                        {
                            <span style="color: gold;">★</span>
                        }
                        else
                        {
                            <span style="color: #ccc;">★</span>
                        }
                    }
                </p>


                <p class="mb-2">
                    <strong>Nội dung:</strong><br />
                    @dg.NoiDung
                </p>

                <hr />


                @if (dg.PhanHois != null && dg.PhanHois.Any())
                {
                    <div class="bg-light p-3 rounded">
                        <h6 class="text-success mb-2">
                            <i class="fas fa-reply"></i> Phản hồi từ shop
                        </h6>

                        @foreach (var ph in dg.PhanHois)
                        {
                            <div class="border-left pl-3 mb-2">
                                <p class="mb-1">@ph.NoiDung</p>
                                <small class="text-muted">
                                    @ph.TenNguoiDung -
                                    @ph.NgayPhanHoi.ToString("dd/MM/yyyy")
                                </small>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted">
                        <i>Shop chưa phản hồi đánh giá này.</i>
                    </p>
                }
            </div>
        </div>
    }
}


<div class="mt-3">
    <a href="@Url.Action("Profile", "NguoiDung")" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> Quay lại hồ sơ
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mt-2">
        <i class="fas fa-check-circle"></i>
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger mt-3">
        @TempData["Error"]
    </div>
}