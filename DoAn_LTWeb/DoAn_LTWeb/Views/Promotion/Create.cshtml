
@{
    ViewBag.Title = "Create";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@model DoAn_LTWeb.Models.KhuyenMai

<h2>Thêm khuyến mãi</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="form-group">
        <label>Tên khuyến mãi</label>
        @Html.TextBoxFor(m => m.TenKM, new { @class = "form-control", required = true })
    </div>

    <div class="form-group mb-3">
        <label>Sản phẩm áp dụng</label>
        @Html.DropDownListFor(
            m => m.MaSanPham,
            ViewBag.MaSanPham as SelectList,
            "-- Chọn sản phẩm --",
            new { @class = "form-control", required = "required" }
        )
    </div>

    <div class="form-group">
        <label>% Giảm</label>
        @Html.TextBoxFor(m => m.MucGiam, new { @class = "form-control", type = "number", min = "1", max = "100" })
    </div>

    <div class="form-group">
        <label>Ngày bắt đầu</label>
        @Html.TextBoxFor(m => m.NgayBD, "{0:yyyy-MM-dd}", new { type = "date", @class = "form-control" })
    </div>

    <div class="form-group">
        <label>Ngày kết thúc</label>
        @Html.TextBoxFor(m => m.NgayKT, "{0:yyyy-MM-dd}", new { type = "date", @class = "form-control" })
    </div>

    <div class="form-group">
        <label>Mô tả</label>
        @Html.TextAreaFor(m => m.MoTa, new { @class = "form-control" })
    </div>

    <button type="submit" class="btn btn-primary">Lưu</button>
    <a class="btn btn-secondary" href="@Url.Action("Index")">Quay lại</a>
}
