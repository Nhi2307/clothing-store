@model IEnumerable<DoAn_LTWeb.Models.LienHe>
@{
    ViewBag.Title = "Danh sách Liên Hệ";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <h3 class="mb-3"> Quản lý liên hệ </h3>

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover table-bordered">
                <thead class="table-primary">
                    <tr>
                        <th>STT</th>
                        <th>Họ và tên</th>
                        <th>Email</th>
                        <th>Nội dung</th>
                        <th>Ngày gửi</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center">Chưa có liên hệ nào</td>
                        </tr>
                    }
                    else
                    {
                        int stt = 1;
                        foreach (var item in Model)
                        {
                <tr>
                    <td>@stt</td>
                    <td>@item.Name</td>
                    <td>@item.Email</td>
                    <td>@item.Message</td>
                    <td>@(item.CreatedAt.HasValue ? item.CreatedAt.Value.ToString("dd/MM/yyyy HH:mm") : "")</td>
                    <td>
                        <a href="@Url.Action("ChiTiet", "LienHe", new { id = item.ID })"
                           class="btn btn-info btn-sm">
                            <i class="fas fa-eye"></i> Xem
                        </a>

                        <a href="@Url.Action("Xoa", "LienHe", new { id = item.ID })"
                           class="btn btn-danger btn-sm"
                           onclick="return confirm('Bạn có chắc muốn xóa liên hệ này?');">
                            <i class="fas fa-trash"></i> Xóa
                        </a>
                    </td>
                </tr>
                            stt++;
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .table th, .table td {
        vertical-align: middle;
    }
</style>
