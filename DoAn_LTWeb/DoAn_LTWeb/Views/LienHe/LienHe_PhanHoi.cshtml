@model List<DoAn_LTWeb.Models.LienHeVM>
@{
    ViewBag.Title = "Liên hệ của tôi";
}

<h3>Liên hệ của tôi</h3>

@if (Model != null && Model.Count > 0)
{
    foreach (var lh in Model)
    {
        <div class="card p-3 mb-3 shadow-sm">
            <p><strong>Nội dung gửi:</strong> @lh.Message</p>
            <p><strong>Thời gian gửi:</strong> @lh.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>

            @if (lh.PhanHois != null && lh.PhanHois.Count > 0)
            {
                <div class="mt-2">
                    @foreach (var ph in lh.PhanHois)
                    {
                        <div class="card p-2 mb-2 bg-light">
                            <p><strong>Chủ shop:</strong> @ph.TenAdmin</p>
                            <p><strong>Ngày phản hồi:</strong> @ph.NgayPhanHoi.ToString("dd/MM/yyyy HH:mm")</p>
                            <p>@ph.NoiDung</p>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-muted mt-2">Chưa có phản hồi từ Admin.</p>
            }

            <a href="@Url.Action("ChiTiet", "LienHe", new { id = lh.ID })" class="btn btn-outline-primary mt-2">Xem chi tiết</a>
        </div>
    }
}
else
{
    <p>Bạn chưa gửi liên hệ nào.</p>
}

<div class="mt-3">
    <a href="@Url.Action("Profile", "NguoiDung")" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> Quay lại hồ sơ
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mt-2">
        <i class="fas fa-check-circle"></i>
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger mt-3">
        @TempData["Error"]
    </div>
}
