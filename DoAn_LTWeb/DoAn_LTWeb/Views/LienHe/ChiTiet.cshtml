@model DoAn_LTWeb.Models.LienHe
@{
    ViewBag.Title = "Chi tiết liên hệ";
    var phanHois = ViewBag.PhanHois as List<DoAn_LTWeb.Models.PhanHoiLienHeVM>;
    var vaiTro = Session["VaiTro"]?.ToString();
}

<h3>Chi tiết liên hệ</h3>

<div class="card p-3 mb-4 shadow-sm">
    <p><strong>Họ tên:</strong> @Model.Name</p>
    <p><strong>Email:</strong> @Model.Email</p>
    <p><strong>Thời gian gửi:</strong> @(Model.CreatedAt.Value.ToString("dd/MM/yyyy HH:mm"))</p>
    <p><strong>Nội dung:</strong></p>
    <p>@Model.Message</p>
</div>

<h4>Phản hồi từ hệ thống</h4>

@if (phanHois != null && phanHois.Any())
{
    foreach (var ph in phanHois)
    {
        <div class="card p-2 mb-2 bg-light">
            <p>
                <strong>Người phản hồi:</strong> @ph.TenAdmin
            </p>
            <p><strong>Ngày phản hồi:</strong> @ph.NgayPhanHoi.ToString("dd/MM/yyyy HH:mm")</p>
            <p>@ph.NoiDung</p>
        </div>
    }
}
else
{
    <p>Chưa có phản hồi.</p>
}


@if (vaiTro == "KhachHang")
{
    <div class="mt-3">
        <a href="@Url.Action("LienHe_PhanHoi", "LienHe")" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Quay lại hồ sơ
        </a>
    </div>
}

@if (vaiTro == "Admin" || vaiTro == "NhanVien")
{
    <h4 class="mt-4">Gửi phản hồi</h4>

    using (Html.BeginForm("PhanHoi", "LienHe", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        @Html.Hidden("maLienHe", Model.ID)

        <div class="form-group">
            <label>Nội dung phản hồi</label>
            <textarea class="form-control" name="noiDung" rows="4" required></textarea>
        </div>

        <button type="submit" class="btn btn-primary mt-2">
            <i class="fas fa-paper-plane"></i> Gửi phản hồi
        </button>
    }

    <a href="@Url.Action("DSLienHe", "LienHe")"
       class="btn btn-secondary mt-3">
        Quay lại danh sách liên hệ
    </a>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mt-3">
        <i class="fas fa-check-circle"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger mt-3">
        <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
    </div>
}
