@model DoAn_LTWeb.Models.Contact
@{
    ViewBag.Title = "Liên hệ";
    Layout = "~/Views/Shared/UserLayout.cshtml";
}

<div class="container py-4">
    <div  class="row align-items-stretch">
        <div class="col-lg-7">

            <div class="info-box p-4 shadow-sm mb-4">
                <h4 class="mb-3">THÔNG TIN LIÊN HỆ</h4>

                <p><strong>Địa chỉ:</strong><br> 140 Lê Trọng Tấn, Tây Thạnh, Tân Phú, TP.HCM</p>
                <p><strong>Email:</strong><br> kcntt@hufi.edu.vn</p>
                <p><strong>Điện thoại:</strong><br> (028) 3816 1673 (ext 136)</p>
                <p><strong>Thời gian làm việc:</strong><br> Thứ 2 – Thứ 7 (8h00 – 17h00)</p>
            </div>

            <div class="form-box p-4 shadow-sm">
                <h4 class="mb-3">GỬI THÔNG TIN</h4>

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger">
                        <i class="fas fa-exclamation-triangle"></i> @TempData["Error"]
                    </div>
                }

                @using (Html.BeginForm("Index", "LienHe", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()

                    @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="fw-bold">Họ và tên</label>
                            @Html.TextBoxFor(m => m.Name, new
                            {
                                @class = "form-control",
                                placeholder = "Nhập họ và tên"
                            })
                            @Html.ValidationMessageFor(m => m.Name, "", new { @class = "text-danger" })
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="fw-bold">Email</label>
                            @Html.TextBoxFor(m => m.Email, new
                            {
                                @class = "form-control",
                                placeholder = "Nhập email"
                            })
                            @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                        </div>

                        <div class="col-12 mb-3">
                            <label class="fw-bold">Nội dung</label>
                            @Html.TextAreaFor(m => m.Message, new
                            {
                                @class = "form-control",
                                rows = 5,
                                placeholder = "Nhập nội dung liên hệ"
                            })
                            @Html.ValidationMessageFor(m => m.Message, "", new { @class = "text-danger" })
                        </div>

                        <div class="col-12">
                            <button type="submit" class="btn btn-dark w-100 py-2">
                                Gửi ngay
                            </button>
                        </div>
                    </div>
                }

            </div>
        </div>

        <div class="col-lg-5 mt-4 mt-lg-0">
            <div class="map-container shadow-sm">
                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3919.062394843006!2d106.62643337451753!3d10.806533258638707!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x31752be27d8b4f4d%3A0x92dcba2950430867!2zVHLGsOG7nW5nIMSQ4bqhaSBo4buNYyBDw7RuZyBUaMawxqFuZyBUUC4gSOG7kyBDaMOtIE1pbmggKEhVSVQp!5e0!3m2!1svi!2s!4v1764655732132!5m2!1svi!2s"
                        loading="lazy"
                        allowfullscreen="">
                </iframe>
            </div>
        </div>

    </div>

</div>

<style>
    .contact-title {
        font-size: 32px;
        font-weight: 700;
        border-left: 5px solid #ff6600;
        padding-left: 12px;
    }

    .info-box, .form-box {
        background: #fff;
        border-radius: 10px;
        border: 1px solid #e5e5e5;
    }

    .map-container {
        width: 100%;
        height: 380px; 
        border-radius: 12px;
        overflow: hidden;
    }

        .map-container iframe {
            width: 100%;
            height: 100%;
            border: 0;
        }

    input.form-control, textarea.form-control {
        border-radius: 6px;
        border: 1px solid #ccc;
    }

        input.form-control:focus, textarea.form-control:focus {
            border-color: #ff6600;
            box-shadow: none;
        }

    .btn-dark {
        background: #333;
        border: none;
    }

        .btn-dark:hover {
            background: #000;
        }
</style>