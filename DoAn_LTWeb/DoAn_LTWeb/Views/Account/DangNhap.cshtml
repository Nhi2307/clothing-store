@{
    ViewBag.Title = "Đăng Nhập";
    Layout = "~/Views/Shared/UserLayout.cshtml";
}

@if (TempData["DangKyThanhCong"] != null)
{
    <div class="alert alert-success">
        <i class="fas fa-check-circle"></i> @TempData["DangKyThanhCong"]
    </div>
}

@if (TempData["ErrorLogin"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorLogin"]
    </div>
}



<div class="d-flex flex-column justify-content-center" style="min-height: calc(100vh - 70px)">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm card-custom-border custom-card-bg">
                <div class="card-header text-white text-center custom-header">
                    <h3 class="mb-0"><i class="fas fa-sign-in-alt"></i> Đăng Nhập</h3>
                </div>

                <div class="card-body p-4">
                    @if (TempData["ErrorLogin"] != null)
                    {
                        <div class="alert alert-warning">
                            <i class="fas fa-exclamation-triangle"></i> @TempData["ErrorLogin"]
                        </div>
                    }

                    @using (Html.BeginForm("DangNhap", "Account", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()

                        <div class="form-group mb-3">
                            <label for="email"><i class="fas fa-envelope icon-custom"></i> Email</label>
                            <input type="email" name="email" id="email" class="form-control custom-input" placeholder="Nhập email" required />
                        </div>

                        <div class="form-group mb-3">
                            <label for="matKhau"><i class="fas fa-lock icon-custom"></i> Mật khẩu</label>
                            <input type="password" name="matKhau" id="matKhau" class="form-control custom-input" placeholder="Nhập mật khẩu" required />
                        </div>

                        <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

                        <button type="submit" class="btn custom-btn w-100">
                            <i class="fas fa-sign-in-alt"></i> Đăng Nhập
                        </button>

                        <div class="text-center mt-3">
                            <span>Chưa có tài khoản? <a href="@Url.Action("DangKy", "Account")" class="link-custom">Đăng ký</a></span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>

    .custom-card-bg {
        background-color: #ffffff;
        border-radius: 14px;
        overflow: hidden;
    }

    .card-custom-border {
        border: 1px solid #d4d4d4;
    }

    .custom-header {
        background-color: #2f2f2f;
        border-radius: 14px 14px 0 0;
    }

    .icon-custom {
        color: #c8b9a6;
        margin-right: 6px;
    }

    .custom-input {
        border-radius: 10px;
        border: 1px solid #cfcfcf;
        background: #fafafa;
    }

        .custom-input:focus {
            border-color: #a8a8a8;
            box-shadow: none;
        }

    .custom-btn {
        background-color: #2f2f2f;
        border: none;
        color: white;
        border-radius: 10px;
        padding: 10px;
        font-size: 16px;
    }

        .custom-btn:hover {
            background-color: #1e1e1e;
        }

    .link-custom {
        color: #2f2f2f;
        font-weight: 600;
    }

        .link-custom:hover {
            color: #000;
        }

    .card:hover {
        box-shadow: 0 6px 20px rgba(0,0,0,0.1);
        transition: 0.3s;
    }
</style>